.tmp/
.codex-pytest-temp/
.pytest-tmp/
tmp_pytest/
scratch*/
pytest-cache-files-*/

# Python caches and tooling
__pycache__/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/
.ipynb_checkpoints/

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local notebooks and experiment output
notebooks/*
